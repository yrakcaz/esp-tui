{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); echo \"$cmd\" | grep -qE 'git push' || exit 0; cargo fmt --check && cargo clippy --all-targets && cargo test --all-targets",
            "timeout": 120,
            "statusMessage": "Running fmt/clippy/tests before push..."
          }
        ]
      }
    ]
  }
}
